#include <iostream>
#include <thread>
#include <string>
#include <chrono>

using namespace std;

void misaludo(string m, int demora, int veces) //funcion cuyo objetivo es crear el nuevo hilo
{
    for (int i =  1; i <= veces; i++)
        {
            cout <<m+"\n";
            this_thread::sleep_for(chrono::milliseconds(demora)); //este hilo se detiene durante (demora) milisegundos
        }
}
int main ()
{
    //se crean los 3 hilos
    thread th_1(&misaludo, "Soy A", 100, 10);
    thread th_2(&misaludo,"\t\t Soy B", 150, 15);
    thread th_3(&misaludo,"\t\t\t Soy C", 50, 10);

    th_1.join(); //hilo principal espera a que el nuevo hilo finalice
    th_2.join();
    th_3.join();

    cout <<"Fin \n";

    return 0;
    
    
}
